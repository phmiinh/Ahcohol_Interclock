{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Demo Firmware",
      "type": "shell",
      "command": "pio run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Demo Build",
      "type": "shell",
      "command": "pio run -t clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
